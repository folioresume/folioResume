GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Groq fallback (used when Gemini fails or is unavailable)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
PORT=4000
CLIENT_ORIGIN=http://localhost:3000
# Use origins only: scheme + hostname + optional port. Do not include paths.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
ALLOWED_HOSTS=
API_KEY=
JWT_SECRET=
MONGODB_URI=mongodb://127.0.0.1:27017/resume_parser
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20
UPLOAD_RATE_LIMIT_MAX=10
IMAGE_UPLOAD_RATE_LIMIT_MAX=30

GOOGLE_CLIENT_ID=

OTP_TTL_MINUTES=10
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=FolioResume <your-email@gmail.com>

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_PROJECT_NAME=resume-parser

PORTFOLIO_BASE_URL=http://localhost:3001

# Razorpay payment gateway
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Pricing & free-usage config (no code change needed to adjust these)
FREE_PARSE_LIMIT=3
PORTFOLIO_PRICE=99
FOUNDING_PRICE=49
FOUNDING_USER_LIMIT=100
PAYMENT_RATE_LIMIT_MAX=10
